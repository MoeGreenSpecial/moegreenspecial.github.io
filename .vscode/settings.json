{
    "cSpell.enabled": true,
    "cSpell.language": "en",
    "cSpell.ignorePaths": [
        ".git/**",
        ".github/**",
        ".vscode/**",
        "_sass/**",
        "_site/**",
        "Gemfile",
        "Gemfile.lock"
    ],
    "cSpell.enabledFileTypes": {
        "markdown": true,
        "html": true
    },
    "cSpell.customDictionaries": {
        "project-words": {
            "name": "project-words",
            "path": "${workspaceFolder}/.vscode/ltex.dictionary.en-US.txt",
            "addWords": false,
            "scope": "workspace"
        }
    },
    "files.eol": "\n",
    "ltex.enabled": true,
    "ltex.language": "en-US"
}